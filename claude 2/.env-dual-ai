# ============================================
# Saboora - Dual AI System Configuration
# ============================================

# ============================================
# Server
# ============================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# JWT Secret
# ============================================
JWT_SECRET=change-this-to-a-random-secure-string

# ============================================
# AI Provider (Required - at least ONE)
# ============================================

# Groq API (Recommended - Free!)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ============================================
# Image Search (Required for whiteboard images)
# ============================================

# Unsplash API (Free - 50 requests/hour)
# Get it from: https://unsplash.com/oauth/applications
# 1. Create a new application
# 2. Copy the "Access Key"
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ============================================
# Database (Optional for now)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ============================================
# Payment (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ============================================
# IMPORTANT NOTES:
# ============================================
# ✅ REQUIRED for the system to work:
#    - GROQ_API_KEY
#    - UNSPLASH_ACCESS_KEY
#
# ⚠️ DO NOT share this file with anyone!
# ⚠️ DO NOT commit this file to GitHub!
# ⚠️ Change JWT_SECRET to a secure random string!
